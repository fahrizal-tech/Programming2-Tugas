	<queryString>
		<![CDATA[SELECT n.id_nilai, n.nim, m.nama, n.kode_mk, mk.nama_mk, n.nilai_tugas, n.nilai_uts, n.nilai_uas FROM nilai n JOIN mahasiswa m ON n.nim = m.nim JOIN mata_kuliah mk ON n.kode_mk = mk.kode_mk ORDER BY n.id_nilai ASC]]>
	</queryString>
